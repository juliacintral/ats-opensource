# Banco de dados (Neon ou Supabase)
DATABASE_URL="postgresql://user:password@host:5432/ats?sslmode=require"

# JWT
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="outro-segredo-longo"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Supabase Storage (opcional — pode usar Cloudinary free ou base64)
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_KEY="eyJ..."

# Email SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seuemail@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="ATS <seuemail@gmail.com>"

# IA — escolha um:
# Ollama local
AI_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:latest"

# OU OpenRouter (gratuito)
# AI_PROVIDER="openrouter"
# OPENROUTER_API_KEY="sk-or-..."
# OPENROUTER_MODEL="meta-llama/llama-3-8b-instruct:free"

NEXTAUTH_URL="http://localhost:3000"
