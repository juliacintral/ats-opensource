# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://ats_user:ats_pass@localhost:5432/ats_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=sua-chave-secreta-super-segura-mude-em-producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=sua-chave-refresh-super-segura-mude-em-producao
JWT_REFRESH_EXPIRES_IN=7d

# Storage (escolha um)
# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-anon
SUPABASE_BUCKET=resumes

# MinIO (self-hosted)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=resumes

# AI Provider
AI_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3

# OpenRouter (alternativa gratuita remota)
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
