# Email (escolha um)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu@gmail.com
MAIL_PASS=sua-senha-de-app
MAIL_FROM=noreply@seuats.com
