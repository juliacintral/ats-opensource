# ============================================
# VARIÁVEIS OBRIGATÓRIAS (MVP — apenas 4)
# ============================================

# 1. Banco de dados (Supabase Free)
# Como pegar: supabase.com → Settings → Database → Connection string → URI
# Adicione ?pgbouncer=true&connection_limit=1 no final
DATABASE_URL="postgresql://postgres:SuaSenha@db.XXXXXXXX.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# 2. Segredo JWT (invente qualquer texto longo)
JWT_SECRET="ats-jwt-secret-troque-isso-por-algo-unico"

# 3. Segredo Refresh Token (invente outro texto diferente)
REFRESH_TOKEN_SECRET="ats-refresh-secret-diferente-do-jwt"

# 4. URL do frontend (preencha após criar o projeto frontend no Vercel)
FRONTEND_URL="https://seu-frontend.vercel.app"

# ============================================
# OPCIONAIS (deixe em branco no MVP)
# ============================================

# Redis (sem isso usa cache em memória automaticamente)
REDIS_URL=

# IA local com Ollama (sem isso a IA fica desativada)
OLLAMA_URL=

# Storage de currículos (sem isso usa upload local temporário)
SUPABASE_URL=
SUPABASE_ANON_KEY=
STORAGE_BUCKET=

# E-mail (sem isso os e-mails são logados no console)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ============================================
# VARIÁVEIS AUTOMÁTICAS (não precisa mudar)
# ============================================
NODE_ENV=production
PORT=3001
