# ─── Aplicação ────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ─── Banco de Dados ───────────────────────────────────────────
# Neon free: postgresql://user:pass@host/db?sslmode=require
# Supabase free: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ats_dev

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=troque-este-secret-em-producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-este-refresh-secret-em-producao
JWT_REFRESH_DAYS=7

# ─── IA (escolha um provedor) ─────────────────────────────────
# Ollama local (padrão):
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

# OpenRouter free tier (alternativa):
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-xxx
# OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# ─── Storage (currículos) ─────────────────────────────────────
# Supabase Storage (gratuito):
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=resumes

# ─── E-mail ───────────────────────────────────────────────────
# Gmail SMTP (gratuito) — use uma App Password:
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seuemail@gmail.com
MAIL_PASS=app-password-aqui
MAIL_FROM="ATS Open Source <seuemail@gmail.com>"
