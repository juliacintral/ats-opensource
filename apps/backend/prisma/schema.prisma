generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RECRUITER
  HIRING_MANAGER
  CANDIDATE
}

enum JobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum InterviewType {
  PHONE
  VIDEO
  ONSITE
  TECHNICAL
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(RECRUITER)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs             Job[]           @relation("JobRecruiter")
  interviews       Interview[]     @relation("Interviewer")
  feedbacks        Feedback[]
  refreshTokens    RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Job {
  id            String    @id @default(uuid())
  title         String
  description   String
  requirements  String?
  location      String?
  isRemote      Boolean   @default(false)
  salaryMin     Decimal?
  salaryMax     Decimal?
  salaryCurrency String?  @default("BRL")
  department    String?
  status        JobStatus @default(DRAFT)
  recruiterId   String
  recruiter     User      @relation("JobRecruiter", fields: [recruiterId], references: [id])
  pipeline      Stage[]
  applications  Application[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("jobs")
}

model Stage {
  id           String        @id @default(uuid())
  name         String
  order        Int
  jobId        String
  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applications Application[]
  createdAt    DateTime      @default(now())

  @@unique([jobId, order])
  @@map("stages")
}

model Candidate {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  resumeUrl    String?
  resumeText   String?  // Extracted text from resume PDF
  parsedResume Json?    // Structured data from AI parsing
  aiSummary    String?  // AI-generated candidate summary
  source       String?  // LinkedIn, Referral, Job Board, etc.
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications Application[]

  @@map("candidates")
}

model Application {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   Candidate         @relation(fields: [candidateId], references: [id])
  stageId     String?
  stage       Stage?            @relation(fields: [stageId], references: [id])
  status      ApplicationStatus @default(APPLIED)
  aiScore     Float?            // AI ranking score 0-100
  notes       String?
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  interviews  Interview[]
  feedbacks   Feedback[]

  @@unique([jobId, candidateId])
  @@map("applications")
}

model Interview {
  id            String          @id @default(uuid())
  applicationId String
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewerId String
  interviewer   User            @relation("Interviewer", fields: [interviewerId], references: [id])
  type          InterviewType   @default(VIDEO)
  status        InterviewStatus @default(SCHEDULED)
  scheduledAt   DateTime
  durationMin   Int             @default(60)
  meetingUrl    String?         // Google Meet / Teams link
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  feedback      Feedback?

  @@map("interviews")
}

model Feedback {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewId   String?     @unique
  interview     Interview?  @relation(fields: [interviewId], references: [id])
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  rating        Int         // 1-5
  recommendation String     // STRONG_YES, YES, NO, STRONG_NO
  strengths     String?
  weaknesses    String?
  notes         String?
  createdAt     DateTime    @default(now())

  @@map("feedbacks")
}
