generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
}

enum JobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  ACTIVE
  HIRED
  REJECTED
  WITHDRAWN
}

enum Recommendation {
  STRONG_YES
  YES
  NEUTRAL
  NO
  STRONG_NO
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          Role           @default(RECRUITER)
  avatarUrl     String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  interviews    Interview[]    @relation("Interviewer")
  feedbacks     Feedback[]
  jobs          Job[]          @relation("Recruiter")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model Job {
  id           String        @id @default(cuid())
  title        String
  description  String?
  requirements String?
  department   String?
  location     String?
  type         String        @default("FULL_TIME")
  status       JobStatus     @default(OPEN)
  salaryMin    Float?
  salaryMax    Float?
  recruiterId  String?
  recruiter    User?         @relation("Recruiter", fields: [recruiterId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pipeline     Stage[]
  applications Application[]
}

model Stage {
  id           String        @id @default(cuid())
  name         String
  order        Int
  color        String        @default("#6366f1")
  jobId        String
  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applications Application[] @relation("CurrentStage")
}

model Candidate {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String?
  linkedin     String?
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  skills       String[]
  resumeUrl    String?
  resumeText   String?
  parsedResume Json?
  aiSummary    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Application {
  id             String            @id @default(cuid())
  candidateId    String
  candidate      Candidate         @relation(fields: [candidateId], references: [id])
  jobId          String
  job            Job               @relation(fields: [jobId], references: [id])
  currentStageId String?
  currentStage   Stage?            @relation("CurrentStage", fields: [currentStageId], references: [id])
  status         ApplicationStatus @default(ACTIVE)
  aiScore        Float?
  notes          String?
  appliedAt      DateTime          @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  interviews     Interview[]
  feedbacks      Feedback[]

  @@unique([jobId, candidateId])
}

model Interview {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  interviewerId String
  interviewer   User        @relation("Interviewer", fields: [interviewerId], references: [id])
  scheduledAt   DateTime
  duration      Int         @default(60)
  type          String      @default("VIDEO")
  meetLink      String?
  meetingUrl    String?
  status        String      @default("SCHEDULED")
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  feedbacks     Feedback[]
}

model Feedback {
  id             String          @id @default(cuid())
  applicationId  String
  application    Application     @relation(fields: [applicationId], references: [id])
  interviewId    String?
  interview      Interview?      @relation(fields: [interviewId], references: [id])
  authorId       String
  author         User            @relation(fields: [authorId], references: [id])
  content        String
  rating         Int?
  recommendation Recommendation?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}
