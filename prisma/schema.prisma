generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
}

enum JobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  ACTIVE
  REJECTED
  HIRED
  WITHDRAWN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(RECRUITER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs         Job[]
  interviews   Interview[] @relation("InterviewerRelation")
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Job {
  id          String    @id @default(cuid())
  title       String
  description String?
  location    String?
  salary      String?
  status      JobStatus @default(DRAFT)
  searchVec   Unsupported("tsvector")?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  stages       Stage[]
  applications Application[]

  @@map("jobs")
}

model Stage {
  id       String @id @default(cuid())
  name     String
  order    Int
  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  applications Application[]

  @@map("stages")
}

model Candidate {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  resumeUrl    String?
  resumeText   String?
  resumeJson   Json?
  linkedinUrl  String?
  searchVec    Unsupported("tsvector")?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications Application[]

  @@map("candidates")
}

model Application {
  id          String            @id @default(cuid())
  candidateId String
  jobId       String
  stageId     String?
  status      ApplicationStatus @default(ACTIVE)
  aiScore     Float?
  aiNotes     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  candidate  Candidate   @relation(fields: [candidateId], references: [id])
  job        Job         @relation(fields: [jobId], references: [id])
  stage      Stage?      @relation(fields: [stageId], references: [id])
  interviews Interview[]
  feedbacks  Feedback[]

  @@unique([candidateId, jobId])
  @@map("applications")
}

model Interview {
  id            String   @id @default(cuid())
  applicationId String
  interviewerId String
  scheduledAt   DateTime
  meetUrl       String?
  notes         String?
  createdAt     DateTime @default(now())

  application  Application @relation(fields: [applicationId], references: [id])
  interviewer  User        @relation("InterviewerRelation", fields: [interviewerId], references: [id])
  feedbacks    Feedback[]

  @@map("interviews")
}

model Feedback {
  id            String   @id @default(cuid())
  applicationId String
  interviewId   String?
  authorId      String
  rating        Int      // 1-5
  notes         String
  recommendation String  // STRONG_YES / YES / NO / STRONG_NO
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  interview   Interview?  @relation(fields: [interviewId], references: [id])

  @@map("feedbacks")
}
